<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Amr3DPreview" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_orange</item>
        <item name="colorPrimaryDark">@color/background_dark</item>
        <item name="colorAccent">@color/accent_blue</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
    </style>

    <style name="Theme.Amr3DPreview.Fullscreen" parent="Theme.Amr3DPreview">
        <!-- ⚠️ الخصائص القديمة (windowFullscreen, windowTranslucentStatus,
             windowTranslucentNavigation, windowDrawsSystemBarBackgrounds) اتشالت من
             هنا لأنها كانت بتتعارض مع الطريقة الحديثة اللي الكود بيستخدمها فعليًا في
             SplashActivity.kt (WindowCompat.setDecorFitsSystemWindows + 
             WindowInsetsControllerCompat) — الخلط بين الطريقتين كان سبب ظهور شريط أسود
             ثابت أعلى الشاشة مش بياخد لون الثيم (خصوصًا في الوضع الفاتح). الكود بالفعل
             بيتحكم في الـ status bar/navigation bar بنفسه بالكامل، فمحتاجينش تعريفات
             هنا تعارضه. -->
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="SplashProgressBar" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:progressDrawable">@drawable/splash_progress_bar</item>
        <item name="android:minHeight">10dp</item>
        <item name="android:maxHeight">10dp</item>
    </style>
</resources>
